# Keep the build context tight — bind-mount of source happens at runtime
.venv
.pytest_cache
.mypy_cache
.ruff_cache
__pycache__
*.pyc
*.pyo

# Local env
.env
.env.local

# VCS
.git
.gitignore

# Editor
.vscode
.idea
*.swp

# Throwaway analysis/diagnostic scripts — never ship to production
diagnostics/

# Runtime data — the forward board archive accumulates on the server; a
# locally captured board must not be baked into the image.
prediction_boards/
