# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_FORMAT=json
API_V1_PREFIX=/api/v1

# Postgres (asyncpg driver). Host-side port is 5433 to avoid colliding with
# a system PostgreSQL that may already be listening on 5432.
DATABASE_URL=postgresql+asyncpg://pga:pga@localhost:5433/pga

# Redis
REDIS_URL=redis://localhost:6379/0
